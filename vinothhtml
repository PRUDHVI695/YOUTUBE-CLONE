    <style>
      body {
        background: #f9f9f9
          url(https://www.mindchirps.com/background/background15.jpg) no-repeat
          center center fixed;
        color: #333;
        font-family: "Roboto", sans-serif;
        margin: 0;
        padding: 0;
      }

      .card {
        margin-bottom: 15px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }
      .card-header {
        background-color: #1e525b;
        color: #c2f2fc;
        font-weight: bold;
        padding: 10px 15px;
      }
      .card-body {
        display: flex;
        align-items: flex-start;
        padding: 10px 15px;
      }
      .card-body img {
        width: 90px;
        height: auto;
        object-fit: cover;
        margin-right: 15px;
      }
      .btn-secondary {
        background-color: #1e525b;
        border-color: #1e525b;
      }
      .btn-secondary:hover {
        background-color: #16434a;
        border-color: #16434a;
      }

      .sidebar-section {
        background-color: #1e525b;
        color: white;
        padding: 20px;
        margin-bottom: 20px;
        border-radius: 8px;
        font-size: 16px;
      }
      .sidebar-section input[type="email"] {
        width: 100%;
        padding: 8px;
        margin-bottom: 10px;
        border: none;
        border-radius: 4px;
      }

      #footer {
        background-color: #1e525b;
        color: white;
        text-align: center;
        padding: 20px;
        font-size: 14px;
      }

      #footer a {
        color: white;
        margin: 0 10px;
        font-size: 18px;
        transition: color 0.3s ease;
      }
      #footer a:hover {
        color: #c2f2fc;
      }

      .pagination .page-link {
        color: #1e525b;
      }
      .pagination .active .page-link {
        background-color: #1e525b;
        border-color: #1e525b;
        color: white;
      }
    </style>
  </head>
